<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="JesusTheChrist.App.Views.TopicFeedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:JesusTheChrist.Presentation.ViewModels;assembly=JesusTheChrist.Presentation"
    xmlns:loc="clr-namespace:JesusTheChrist.Presentation.Resources;assembly=JesusTheChrist.Presentation"
    x:DataType="vm:TopicFeedViewModel"
    Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="16,12">

        <ActivityIndicator
            Grid.Row="0"
            IsVisible="{Binding IsLoading}"
            IsRunning="{Binding IsLoading}" />

        <CollectionView
            x:Name="ReferencesView"
            Grid.Row="1"
            ItemsSource="{Binding References}"
            SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ReferenceCardViewModel">
                    <Border Padding="14" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Spacing="8">

                            <!-- Heading: narrative gloss (top) + reference, with note + read actions -->
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <VerticalStackLayout
                                    Grid.Column="0"
                                    Spacing="2"
                                    VerticalOptions="Center"
                                    SemanticProperties.Description="{x:Static loc:AppResources.A11yExpandCollapse}">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleExpandedCommand}" />
                                    </VerticalStackLayout.GestureRecognizers>
                                    <Label
                                        Text="{Binding Gloss}"
                                        IsVisible="{Binding HasGloss}"
                                        FontSize="18"
                                        FontAttributes="Bold" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Label
                                            Text="{Binding ChevronGlyph}"
                                            FontSize="13"
                                            Opacity="0.55"
                                            VerticalOptions="Center" />
                                        <Label
                                            Text="{Binding RefLabel}"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            Opacity="0.75"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <!-- Note + read live in the heading only while collapsed; when the
                                     card is expanded they move to the footer so a reader of a long
                                     passage never has to scroll back up to act. -->
                                <Button
                                    Grid.Column="1"
                                    IsVisible="{Binding IsCollapsed}"
                                    Command="{Binding OpenNoteCommand}"
                                    FontSize="13"
                                    Padding="10,4"
                                    CornerRadius="8"
                                    BorderWidth="1"
                                    BorderColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#1C1C1C, Dark=#FFFFFF}"
                                    VerticalOptions="Center">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding HasNote}" Value="True">
                                            <Setter Property="Text" Value="{x:Static loc:AppResources.CardEditNote}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding HasNote}" Value="False">
                                            <Setter Property="Text" Value="{x:Static loc:AppResources.CardAddNote}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Border
                                    Grid.Column="2"
                                    IsVisible="{Binding IsCollapsed}"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    StrokeShape="RoundRectangle 6"
                                    StrokeThickness="1"
                                    VerticalOptions="Center"
                                    SemanticProperties.Description="{x:Static loc:AppResources.A11yToggleRead}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReadCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label
                                        Text="✓"
                                        FontSize="20"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        IsVisible="{Binding IsRead}"
                                        SemanticProperties.Description="{x:Static loc:AppResources.A11yRead}" />
                                </Border>
                            </Grid>

                            <!-- Collapsible body: hidden when the card is rolled up to its heading -->
                            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsExpanded}">

                            <!-- Target verses, each prefixed with its verse number -->
                            <VerticalStackLayout Spacing="6" BindableLayout.ItemsSource="{Binding Verses}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ContextLineViewModel">
                                        <Label FontSize="{DynamicResource ReadingFontSize}" LineHeight="1.35">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Verse}" FontAttributes="Bold" FontSize="{DynamicResource VerseNumberFontSize}" />
                                                    <Span Text="  " />
                                                    <Span Text="{Binding Text}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <!-- Separator -->
                            <BoxView
                                HeightRequest="1"
                                Margin="0,4"
                                Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />

                            <!-- Footer action bar: context toggle on the left, note + read on the
                                 right. These mirror the heading actions but ride at the foot of the
                                 expanded card, so the reader acts right where the passage ends. -->
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <Button
                                    Grid.Column="0"
                                    IsVisible="{Binding HasContext}"
                                    Command="{Binding ToggleContextCommand}"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Center"
                                    FontSize="13"
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#1C1C1C, Dark=#FFFFFF}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsContextVisible}" Value="False">
                                            <Setter Property="Text" Value="{x:Static loc:AppResources.CardShowContext}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsContextVisible}" Value="True">
                                            <Setter Property="Text" Value="{x:Static loc:AppResources.CardHideContext}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding OpenNoteCommand}"
                                    FontSize="13"
                                    Padding="10,4"
                                    CornerRadius="8"
                                    BorderWidth="1"
                                    BorderColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#1C1C1C, Dark=#FFFFFF}"
                                    VerticalOptions="Center">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding HasNote}" Value="True">
                                            <Setter Property="Text" Value="{x:Static loc:AppResources.CardEditNote}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding HasNote}" Value="False">
                                            <Setter Property="Text" Value="{x:Static loc:AppResources.CardAddNote}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Border
                                    Grid.Column="2"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    StrokeShape="RoundRectangle 6"
                                    StrokeThickness="1"
                                    VerticalOptions="Center"
                                    SemanticProperties.Description="{x:Static loc:AppResources.A11yToggleRead}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReadCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label
                                        Text="✓"
                                        FontSize="20"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        IsVisible="{Binding IsRead}"
                                        SemanticProperties.Description="{x:Static loc:AppResources.A11yRead}" />
                                </Border>
                            </Grid>

                            <!-- Context window -->
                            <VerticalStackLayout
                                IsVisible="{Binding IsContextVisible}"
                                Spacing="4"
                                BindableLayout.ItemsSource="{Binding Context}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ContextLineViewModel">
                                        <Label FontSize="{DynamicResource ReadingFontSize}" Opacity="0.85">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsTarget}" Value="True">
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Verse}" FontAttributes="Bold" />
                                                    <Span Text=" " />
                                                    <Span Text="{Binding Text}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            </VerticalStackLayout>
                            <!-- /Collapsible body -->

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>

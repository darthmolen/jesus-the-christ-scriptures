<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="JesusTheChrist.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:JesusTheChrist.Presentation.Resources;assembly=JesusTheChrist.Presentation"
    Title="{x:Static loc:AppResources.SettingsTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Reading font size -->
            <VerticalStackLayout Spacing="6">
                <Label Text="{x:Static loc:AppResources.SettingsReadingFontSize}" FontAttributes="Bold" />
                <Slider x:Name="FontSlider" Minimum="12" Maximum="28" />
                <Label
                    Text="{x:Static loc:AppResources.SettingsFontSample}"
                    FontSize="{DynamicResource ReadingFontSize}" />
            </VerticalStackLayout>

            <!-- Theme -->
            <VerticalStackLayout Spacing="6">
                <Label Text="{x:Static loc:AppResources.SettingsTheme}" FontAttributes="Bold" />
                <Picker x:Name="ThemePicker">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:Static Member="loc:AppResources.ThemeSystem" />
                            <x:Static Member="loc:AppResources.ThemeLight" />
                            <x:Static Member="loc:AppResources.ThemeDark" />
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </VerticalStackLayout>

            <!-- Language -->
            <VerticalStackLayout Spacing="6">
                <Label Text="{x:Static loc:AppResources.SettingsLanguage}" FontAttributes="Bold" />
                <Picker x:Name="LanguagePicker">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:Static Member="loc:AppResources.LanguageEnglish" />
                            <x:Static Member="loc:AppResources.LanguageSpanish" />
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
                <Label Text="{x:Static loc:AppResources.SettingsLanguageNote}" FontSize="12" Opacity="0.7" />
            </VerticalStackLayout>

            <!-- Streak -->
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="{x:Static loc:AppResources.SettingsTrackStreak}" FontAttributes="Bold" />
                    <Label Text="{x:Static loc:AppResources.SettingsStreakHint}" FontSize="12" Opacity="0.7" />
                </VerticalStackLayout>
                <Switch x:Name="StreakSwitch" Grid.Column="1" VerticalOptions="Center" />
            </Grid>

            <!-- About / attribution -->
            <VerticalStackLayout Spacing="6">
                <Label Text="{x:Static loc:AppResources.SettingsAbout}" FontAttributes="Bold" />
                <Label
                    FontSize="13"
                    Opacity="0.8"
                    Text="{x:Static loc:AppResources.SettingsAttribution}" />
                <Button
                    x:Name="InvitationButton"
                    Text="{x:Static loc:AppResources.SettingsReadInvitation}"
                    Clicked="OnReadInvitation"
                    HorizontalOptions="Start"
                    Padding="0"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#1C1C1C, Dark=#FFFFFF}" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

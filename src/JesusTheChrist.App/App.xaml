<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:JesusTheChrist.App"
             x:Class="JesusTheChrist.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Reading comfort: scripture text binds to this via DynamicResource;
                 SettingsViewModel updates it through the AppearanceApplier. -->
            <x:Double x:Key="ReadingFontSize">16</x:Double>

            <!-- Verse-number superscript: kept proportional to ReadingFontSize
                 (~0.6x) by the AppearanceApplier so numbers stay smaller than
                 the verse body text at every slider position. Seeded at 16 * 0.6. -->
            <x:Double x:Key="VerseNumberFontSize">9.6</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="JesusTheChrist.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:JesusTheChrist.App.Views"
    xmlns:loc="clr-namespace:JesusTheChrist.Presentation.Resources;assembly=JesusTheChrist.Presentation"
    Title="{x:Static loc:AppResources.AppTitle}">

    <ShellContent
        Title="{x:Static loc:AppResources.NavHome}"
        ContentTemplate="{DataTemplate views:HomePage}"
        Route="HomePage" />

</Shell>
